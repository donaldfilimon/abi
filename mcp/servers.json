{
  "mcpServers": {
    "abi-mcp": {
      "command": "./zig-out/bin/abi-mcp",
      "args": ["stdio"],
      "workDir": "/Users/donaldfilimon/abi",
      "env": {
        "LOG_LEVEL": "info",
        "ABI_MCP_PORT": "50051",
        "ABI_MCP_HOST": "127.0.0.1"
      },
      "healthCheck": {
        "enabled": true,
        "path": "/health",
        "intervalMs": 10000,
        "timeoutMs": 2000
      },
      "restartPolicy": {
        "maxRetries": 5,
        "backoffMs": 2000
      }
    }
  }
}
