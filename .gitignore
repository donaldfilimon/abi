# ── Cleanup policy: markdown allowlist only ─────────────────────────────
# Ignore all markdown except explicitly allowlisted files.
# NOTE: new docs under docs/ must be added to this allowlist.
*.md

# Root-level project docs
!/AGENTS.md
!/README.md
!/CHANGELOG.md
!/CLAUDE.md
!/GEMINI.md
!/ABI-MEGA-PLUGIN.md
!/SECURITY.md
!/ONBOARDING.md
!/ONBOARDING_INDEX.md
!/SUMMARY.md
!/CODEBASE_REVIEW.md
!/GLOSSARY.md
!/CODE_OF_CONDUCT.md
!/walkthrough.md

# Documentation tree
!/docs/README.md
!/docs/index.md
!/docs/STRUCTURE.md
!/docs/onboarding.md
!/docs/PATTERNS.md
!/docs/ABI_WDBX_ARCHITECTURE.md
!/docs/ZIG_MACOS_LINKER_RESEARCH.md
!/docs/stylesheets/
!/docs/stylesheets/*.css
!/docs/plans/*.md
!/docs/api/*.md
!/docs/guides/*.md
!/docs/spec/*.md
!/docs/contracts/*.md
!/docs/review/*.md
!/docs/superpowers/**/*.md
!/docs/CONTRIBUTING.md

# Claude project skills: keep every skill definition tracked.
# (.claude/skills/** is un-ignored above at line ~177, but the blanket
#  *.md rule re-ignores skill docs — this negation must come after it.)
!.claude/skills/**/SKILL.md
!.agents/skills/**/SKILL.md
!.agents/skills/abi-doc-claims-sync/references/claim-boundaries.md

# Claude project agents: same story — .claude/agents/** is un-ignored above, but
# the blanket *.md rule re-ignores the agent defs, so this rescue must come after it.
!.claude/agents/**/*.md

# modern-refactor plugin tree (skills/agents/plans) — rescue after *.md blanket
!/modern-refactor/
!/modern-refactor/**
!/modern-refactor/**/*.md
!/modern-refactor/.claude/
!/modern-refactor/.claude/**

