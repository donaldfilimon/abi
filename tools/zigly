set -x
set -euo pipefail

# This script is a lightweight wrapper that transparently compiles and runs
# the native zigly CLI manager so that you always have the fastest execution
# speed and the compiled version is managed locally automatically.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ZIGLY_CLI_DIR="$SCRIPT_DIR/zigly_cli"
ZIGLY_BIN="$ZIGLY_CLI_DIR/zig-out/bin/zigly"

needs_bootstrap=false
if [ ! -x "$ZIGLY_BIN" ]; then
    needs_bootstrap=true
elif [ "$ZIGLY_CLI_DIR/build.zig" -nt "$ZIGLY_BIN" ] || [ "$ZIGLY_CLI_DIR/build_wrapper.sh" -nt "$ZIGLY_BIN" ]; then
    needs_bootstrap=true
else
    # Check if any zig source files have been modified since the binary was built
    if [ -n "$(find "$ZIGLY_CLI_DIR/src" -type f -name '*.zig' -newer "$ZIGLY_BIN" -print -quit)" ]; then
        needs_bootstrap=true
    fi
fi

# Ensure the native binary is built and fresh
if [ "$needs_bootstrap" = true ]; then
    echo "==> Bootstrapping native zigly manager..." >&2
    cd "$ZIGLY_CLI_DIR"
    # We don't redirect to /dev/null so the user can see build errors if they occur
    if ! ./build_wrapper.sh; then
        echo "==> ERROR: Failed to bootstrap the native Zigly manager." >&2
        exit 1
    fi
    cd - >/dev/null
fi

if [ -x "$ZIGLY_BIN" ]; then
    exec "$ZIGLY_BIN" "$@"
else
    echo "==> ERROR: Native binary could not be found or executed." >&2
    exit 1
fi
