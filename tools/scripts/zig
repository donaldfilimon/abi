#!/usr/bin/env bash
# Zig shim — delegates to the real zig binary on PATH.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Find zig on PATH, excluding this shim
while IFS= read -r -d: dir; do
    [[ "$dir" == "$SCRIPT_DIR" ]] && continue
    [[ -x "$dir/zig" ]] && exec "$dir/zig" "$@"
done <<< "$PATH:"
echo "error: zig not found on PATH" >&2
exit 1
