#!/usr/bin/env bash
set -euo pipefail

# Zigly - A simple, fast Zig Version Manager
# Usage: zigly <command> [args]

ZIGLY_HOME="${ZIGLY_HOME:-$HOME/.zigly}"
ZIGVERSION_FILE=".zigversion"

# Colors for output
if [ -t 2 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    YELLOW='\033[1;33m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    BLUE=''
    YELLOW=''
    BOLD=''
    NC=''
fi

info() { echo -e "${BLUE}==>${NC} ${BOLD}$1${NC}" >&2; }
success() { echo -e "${GREEN}==>${NC} ${BOLD}$1${NC}" >&2; }
warn() { echo -e "${YELLOW}==>${NC} ${BOLD}WARNING:${NC} $1" >&2; }
error() { echo -e "${RED}==>${NC} ${BOLD}ERROR:${NC} $1" >&2; exit 1; }

usage() {
    cat <<EOF
${BOLD}Zigly - Zig Version Manager${NC}

${BOLD}Usage:${NC} zigly <command> [options]

${BOLD}Commands:${NC}
  ${GREEN}install${NC} [version]    Install a specific version of Zig + ZLS (defaults to .zigversion)
  ${GREEN}use${NC} [version]        Install and set as the active global version (symlinks to ~/.local/bin)
  ${GREEN}list${NC}, ${GREEN}ls${NC}           List installed versions
  ${GREEN}list-remote${NC}, ${GREEN}lsr${NC}    List available versions from ziglang.org
  ${GREEN}current${NC}              Show the currently active version and project status
  ${GREEN}clean${NC}                Remove all cached versions and downloads
  ${GREEN}bootstrap${NC}            One-command project setup (install from .zigversion and link)
  ${GREEN}doctor${NC}               Report toolchain health diagnostics
  ${GREEN}status${NC}               Print path to the active zig binary (useful for scripts)

${BOLD}Examples:${NC}
  zigly install master
  zigly use 0.13.0
  zigly bootstrap
EOF
    exit 1
}

# --- Platform Detection ---
detect_os() {
    case "$(uname -s)" in
        Darwin) ZIG_OS="macos" ;;
        Linux)  ZIG_OS="linux" ;;
        *)      error "Unsupported OS: $(uname -s)" ;;
    esac
}

detect_arch() {
    case "$(uname -m)" in
        arm64|aarch64)  ZIG_ARCH="aarch64" ;;
        x86_64|amd64)   ZIG_ARCH="x86_64" ;;
        i386|i686)      ZIG_ARCH="x86" ;;
        *)              error "Unsupported arch: $(uname -m)" ;;
    esac
}

# --- Utilities ---
try_download() {
    local url="$1"
    local out="$2"
    if command -v curl >/dev/null 2>&1; then
        curl -fL --progress-bar -o "$out" "$url"
    elif command -v wget >/dev/null 2>&1; then
        wget -q --show-progress -O "$out" "$url"
    else
        error "Need curl or wget to download files."
    fi
}

fetch_json() {
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$1"
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "$1"
    fi
}

extract_json_field() {
    local json="$1"
    local field="$2"
    if command -v jq >/dev/null 2>&1; then
        echo "$json" | jq -r "$field" 2>/dev/null || echo ""
    elif command -v python3 >/dev/null 2>&1; then
        # fallback to python if jq is missing
        local py_script="
import json,sys
try:
    d=json.load(sys.stdin)
    for k in '$field'.strip('.').split('.'):
        if k: d=d[int(k)] if k.isdigit() else d[k]
    print(d)
except: pass"
        echo "$json" | python3 -c "$py_script"
    else
        # Very basic grep fallback for top level simple keys
        echo "$json" | grep -o "\"${field}\": *\"[^\"]*\"" | cut -d'"' -f4 || echo ""
    fi
}

# --- Version Resolution ---
get_project_version() {
    if [ -f "$ZIGVERSION_FILE" ]; then
        cat "$ZIGVERSION_FILE" | tr -d '[:space:]'
    else
        echo ""
    fi
}

resolve_version() {
    local req_version="${1:-}"
    if [ -z "$req_version" ]; then
        req_version="$(get_project_version)"
        if [ -z "$req_version" ]; then
            error "No version provided and no .zigversion file found in current directory."
        fi
        info "Using project version from .zigversion: ${YELLOW}$req_version${NC}"
    fi

    if [ "$req_version" = "master" ] || [ "$req_version" = "nightly" ]; then
        local index_json
        index_json=$(fetch_json "https://ziglang.org/download/index.json")
        local master_ver
        master_ver=$(extract_json_field "$index_json" ".master.version")
        if [ -n "$master_ver" ] && [ "$master_ver" != "null" ]; then
            echo "$master_ver"
            return
        fi
        # fallback
        echo "master"
    else
        echo "$req_version"
    fi
}

resolve_master_tarball_url() {
    local index_json
    index_json=$(fetch_json "https://ziglang.org/download/index.json")
    extract_json_field "$index_json" ".master.${ZIG_ARCH}-${ZIG_OS}.tarball"
}

# --- Installation ---
download_zig() {
    local version="$1"
    local cache_dir="$ZIGLY_HOME/versions/$version"
    
    if [ -x "$cache_dir/bin/zig" ]; then
        info "Zig $version is already installed."
        return 0
    fi

    info "Installing Zig $version..."
    mkdir -p "$cache_dir" "$ZIGLY_HOME/tmp"
    
    local tarball="$ZIGLY_HOME/tmp/zig.tar.xz"
    local extract_dir="$ZIGLY_HOME/tmp/extract"
    rm -rf "$extract_dir" && mkdir -p "$extract_dir"

    # Try direct URL first
    local direct_url="https://ziglang.org/builds/zig-${ZIG_ARCH}-${ZIG_OS}-${version}.tar.xz"
    if [[ "$version" != *"dev"* ]]; then
        direct_url="https://ziglang.org/download/${version}/zig-${ZIG_ARCH}-${ZIG_OS}-${version}.tar.xz"
    fi

    if try_download "$direct_url" "$tarball"; then
        info "Download complete."
    else
        info "Exact version tarball not found, resolving via ziglang.org/download/index.json..."
        local master_url
        master_url=$(resolve_master_tarball_url)
        if [ -n "$master_url" ] && [ "$master_url" != "null" ]; then
            if try_download "$master_url" "$tarball"; then
                info "Download complete."
            else
                error "Failed to download Zig from $master_url"
            fi
        else
            error "Failed to resolve download URL for $version"
        fi
    fi

    info "Extracting..."
    tar -xf "$tarball" -C "$extract_dir"
    local inner_dir
    inner_dir=$(ls -1d "$extract_dir"/zig-* 2>/dev/null | head -1)
    
    if [ -z "$inner_dir" ]; then
        error "Unexpected archive structure."
    fi

    mkdir -p "$cache_dir/bin"
    cp "$inner_dir/zig" "$cache_dir/bin/zig" 2>/dev/null || true
    chmod +x "$cache_dir/bin/zig" 2>/dev/null || true
    
    if [ -d "$inner_dir/lib" ]; then
        cp -R "$inner_dir/lib" "$cache_dir/lib"
    fi
    
    rm -rf "$extract_dir" "$tarball"
    success "Zig $version installed to $cache_dir"
}

download_zls() {
    local version="$1"
    local cache_dir="$ZIGLY_HOME/versions/$version"
    
    if [ -x "$cache_dir/bin/zls" ]; then
        info "ZLS is already installed for this version."
        return 0
    fi

    info "Installing ZLS for Zig $version..."
    
    # Check if zvm's ZLS is available as a fallback
    if [ -x "$HOME/.zvm/bin/zls" ] && [ -n "$(find "$HOME/.zvm/bin/zls" -mtime -1 2>/dev/null)" ]; then
         info "Using ZLS from existing zvm installation..."
         mkdir -p "$cache_dir/bin"
         cp "$HOME/.zvm/bin/zls" "$cache_dir/bin/zls"
         chmod +x "$cache_dir/bin/zls"
         return 0
    fi

    local tarball="$ZIGLY_HOME/tmp/zls.tar.xz"
    mkdir -p "$ZIGLY_HOME/tmp"
    
    local zig_major_minor
    zig_major_minor=$(echo "$version" | sed -E 's/^([0-9]+\.[0-9]+).*/\1/')
    
    local api_version=""
    local releases_json
    releases_json=$(fetch_json "https://api.github.com/repos/zigtools/zls/releases?per_page=10")
    
    if command -v jq >/dev/null 2>&1; then
        api_version=$(echo "$releases_json" | jq -r ".[].tag_name | select(startswith(\"$zig_major_minor\"))" | head -1)
    elif command -v python3 >/dev/null 2>&1; then
        api_version=$(echo "$releases_json" | python3 -c "
import json,sys
try:
    for r in json.load(sys.stdin):
        tag = r.get('tag_name', '')
        if tag.startswith('$zig_major_minor'):
            print(tag)
            sys.exit(0)
except: pass" 2>/dev/null)
    fi

    local zls_version=""
    if [ -n "$api_version" ]; then
        local url="https://github.com/zigtools/zls/releases/download/${api_version}/zls-${ZIG_OS}-${ZIG_ARCH}.tar.xz"
        if try_download "$url" "$tarball"; then
            zls_version="$api_version"
        fi
    fi

    # Fallbacks
    if [ -z "$zls_version" ]; then
        for try_version in "0.16.0-dev.1" "0.15.0" "0.14.0"; do
            local url="https://github.com/zigtools/zls/releases/download/${try_version}/zls-${ZIG_OS}-${ZIG_ARCH}.tar.xz"
            if try_download "$url" "$tarball"; then
                zls_version="$try_version"
                break
            fi
        done
    fi

    if [ -z "$zls_version" ]; then
        warn "Could not find a pre-built ZLS matching Zig $version."
        return 0
    fi

    info "Extracting ZLS $zls_version..."
    local extract_dir="$ZIGLY_HOME/tmp/zls_extract"
    rm -rf "$extract_dir" && mkdir -p "$extract_dir"
    tar -xf "$tarball" -C "$extract_dir"
    
    local zls_bin
    zls_bin=$(find "$extract_dir" -name "zls" -type f | head -1)
    if [ -n "$zls_bin" ]; then
        mkdir -p "$cache_dir/bin"
        cp "$zls_bin" "$cache_dir/bin/zls"
        chmod +x "$cache_dir/bin/zls"
        success "ZLS installed."
    else
        warn "ZLS binary not found in the downloaded archive."
    fi
    
    rm -rf "$extract_dir" "$tarball"
}

do_install() {
    local raw_version="${1:-}"
    local version
    version=$(resolve_version "$raw_version")
    
    detect_os
    detect_arch
    
    download_zig "$version"
    download_zls "$version"
}

# --- Linking ---
resolve_local_bin() {
    if [ -d "$HOME/.local/bin" ] || mkdir -p "$HOME/.local/bin" 2>/dev/null; then
        echo "$HOME/.local/bin"
    elif [ -w "/usr/local/bin" ]; then
        echo "/usr/local/bin"
    else
        error "Cannot find a writable local bin directory. Create ~/.local/bin."
    fi
}

do_use() {
    local raw_version="${1:-}"
    local version
    version=$(resolve_version "$raw_version")
    
    do_install "$version"
    
    local cache_dir="$ZIGLY_HOME/versions/$version"
    local local_bin
    local_bin=$(resolve_local_bin)
    
    info "Setting Zig $version as default in $local_bin..."
    
    ln -sf "$cache_dir/bin/zig" "$local_bin/zig"
    success "Symlinked zig -> $local_bin/zig"
    
    if [ -x "$cache_dir/bin/zls" ]; then
        ln -sf "$cache_dir/bin/zls" "$local_bin/zls"
        success "Symlinked zls -> $local_bin/zls"
    fi
    
    # Save active version
    echo "$version" > "$ZIGLY_HOME/default"
    
    case ":$PATH:" in
        *":$local_bin:"*) ;;
        *)
            warn "$local_bin is not on your PATH."
            info "Add this to your shell profile:"
            echo "  export PATH=\"$local_bin:\$PATH\""
            ;;
    esac
}

# --- Listings ---
do_list() {
    info "Installed versions:"
    local active=""
    if [ -f "$ZIGLY_HOME/default" ]; then
        active=$(cat "$ZIGLY_HOME/default")
    fi
    
    if [ -d "$ZIGLY_HOME/versions" ]; then
        for d in "$ZIGLY_HOME/versions"/*; do
            if [ -d "$d" ]; then
                local v=$(basename "$d")
                if [ "$v" = "$active" ]; then
                    echo -e "  ${GREEN}* ${v}${NC} (active)"
                else
                    echo "    ${v}"
                fi
            fi
        done
    else
        echo "  (none)"
    fi
}

do_list_remote() {
    info "Fetching available versions from ziglang.org..."
    local index_json
    index_json=$(fetch_json "https://ziglang.org/download/index.json")
    
    if command -v jq >/dev/null 2>&1; then
        echo "$index_json" | jq -r 'keys[]' | grep -v 'master' | sort -rV | head -n 15
        echo "  master"
    elif command -v python3 >/dev/null 2>&1; then
        echo "$index_json" | python3 -c "
import json,sys
try:
    keys = list(json.load(sys.stdin).keys())
    if 'master' in keys: keys.remove('master')
    for k in sorted(keys, reverse=True)[:15]: print(k)
    print('master')
except: pass"
    else
        warn "Install jq or python3 for better JSON parsing."
    fi
}

do_current() {
    local active="none"
    if [ -f "$ZIGLY_HOME/default" ]; then
        active=$(cat "$ZIGLY_HOME/default")
    fi
    echo -e "Global active version: ${YELLOW}${active}${NC}"
    
    local proj_ver
    proj_ver=$(get_project_version)
    if [ -n "$proj_ver" ]; then
        echo -e "Project .zigversion:   ${YELLOW}${proj_ver}${NC}"
        if [ "$active" != "$proj_ver" ]; then
            warn "Project version does not match global active version."
            info "Run 'zigly use' to activate the project version."
        fi
    fi
}

do_clean() {
    info "Cleaning up $ZIGLY_HOME..."
    rm -rf "$ZIGLY_HOME/tmp"
    rm -rf "$ZIGLY_HOME/versions"
    rm -f "$ZIGLY_HOME/default"
    success "All cached downloads and versions removed."
}

# --- Bootstrap & Doctor ---
do_bootstrap() {
    info "Bootstrapping project environment..."
    
    local proj_ver
    proj_ver=$(get_project_version)
    if [ -z "$proj_ver" ]; then
        error "No .zigversion found. Cannot bootstrap."
    fi
    
    do_use "$proj_ver"
    
    success "Bootstrap complete! You can now run your project builds."
}

do_doctor() {
    info "Toolchain Health Doctor"
    
    echo "OS:         $(uname -s) ($(uname -m))"
    
    local proj_ver
    proj_ver=$(get_project_version)
    echo "Project:    ${proj_ver:-No .zigversion found}"
    
    local zig_bin
    zig_bin=$(command -v zig 2>/dev/null || echo "MISSING")
    echo "Zig path:   $zig_bin"
    
    if [ "$zig_bin" != "MISSING" ]; then
        echo "Zig ver:    $($zig_bin version)"
    fi
    
    local zls_bin
    zls_bin=$(command -v zls 2>/dev/null || echo "MISSING")
    echo "ZLS path:   $zls_bin"
    if [ "$zls_bin" != "MISSING" ]; then
        echo "ZLS ver:    $($zls_bin --version 2>/dev/null || echo 'unknown')"
    fi
    
    local local_bin
    local_bin=$(resolve_local_bin 2>/dev/null || echo "")
    if [ -n "$local_bin" ]; then
        case ":$PATH:" in
            *":$local_bin:"*) echo "PATH:       $local_bin is in PATH" ;;
            *)                echo -e "PATH:       ${RED}$local_bin NOT in PATH${NC}" ;;
        esac
    fi
}

do_status() {
    local version
    version=$(resolve_version "" 2>/dev/null || echo "")
    if [ -z "$version" ]; then
        exit 1
    fi
    local cache_dir="$ZIGLY_HOME/versions/$version"
    if [ -x "$cache_dir/bin/zig" ]; then
        echo "$cache_dir/bin/zig"
    else
        # Auto-install quietly
        do_install "$version" >/dev/null 2>&1
        echo "$cache_dir/bin/zig"
    fi
}


# --- Main CLI ---
if [ $# -eq 0 ]; then
    usage
fi

COMMAND="$1"
shift

case "$COMMAND" in
    install)     do_install "$@" ;;
    use)         do_use "$@" ;;
    list|ls)     do_list ;;
    list-remote|lsr) do_list_remote ;;
    current)     do_current ;;
    clean)       do_clean ;;
    bootstrap)   do_bootstrap ;;
    doctor)      do_doctor ;;
    status)      do_status ;;
    
    # Backwards compatibility for old zigly args
    --status)    do_status ;;
    --install)   do_install "" ;;
    --update)    do_install "" ;; # Treat update as install latest matching .zigversion
    --link)      do_use "" ;;
    --bootstrap) do_bootstrap ;;
    --doctor)    do_doctor ;;
    
    -h|--help)   usage ;;
    *)           error "Unknown command: $COMMAND\nRun 'zigly --help' for usage." ;;
esac
