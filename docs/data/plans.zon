        .slug = "gpu-redesign-v3",
        .title = "GPU Redesign v3",
        .status = "Planned",
        .owner = "Abbey",
        .scope = "Wave 3: Metal/Vulkan policy hardening, GL family consolidation, strict backend creation, and mixed-backend stability.",
        .gate_commands = .{
