    .{
        .name = "messaging",
        .path = "src/features/messaging/mod.zig",
        .description = "Messaging Module\n\nTopic-based pub/sub messaging with MQTT-style pattern matching,\nsynchronous delivery, dead letter queue, and backpressure.\n\nArchitecture:\n- Topic registry with subscriber lists\n- Pattern matching: `events.*` (single-level), `events.#` (multi-level)\n- Bounded message queues with backpressure (returns ChannelFull)\n- Dead letter queue for failed deliveries\n- Synchronous delivery (publish blocks until all subscribers notified)\n- RwLock for concurrent topic lookups",
        .category = "Infrastructure",
        .build_flag = "feat_messaging",
        .symbols = .{
            .{
                .anchor = "pub-fn-init-allocator-std-mem-allocator-config-messagingconfig-messagingerror-void",
                .signature = "pub fn init(allocator: std.mem.Allocator, config: MessagingConfig) MessagingError!void",
                .doc = "Initialize the global messaging singleton.",
