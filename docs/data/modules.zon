    .{
        .name = "cache",
        .path = "src/features/cache/mod.zig",
        .description = "Cache Module\n\nIn-memory caching with LRU/LFU/FIFO/Random eviction, TTL support,\nand thread-safe concurrent access via RwLock.\n\nArchitecture:\n- SwissMap-backed storage for O(1) key lookup\n- 4 eviction strategies: LRU (doubly-linked list), LFU (frequency buckets),\nFIFO (queue), Random (RNG selection)\n- Lazy TTL expiration on get() + size-triggered sweep\n- RwLock for read-heavy concurrency (multiple readers, single writer)\n- Cache owns all keys/values (copies on put, caller borrows on get)",
        .category = "Data & Storage",
        .build_flag = "feat_cache",
        .symbols = .{
            .{
                .anchor = "pub-fn-init-allocator-std-mem-allocator-config-cacheconfig-cacheerror-void",
                .signature = "pub fn init(allocator: std.mem.Allocator, config: CacheConfig) CacheError!void",
                .doc = "Initialize the global cache singleton with the given configuration.\nNo-op if already initialized.",
                .kind = "fn",
                .line = 370,
            },
            .{
                .anchor = "pub-fn-deinit-void",
                .signature = "pub fn deinit() void",
                .doc = "Tear down the cache, freeing all entries and internal structures.",
                .kind = "fn",
                .line = 376,
            },
            .{
                .anchor = "pub-fn-isenabled-bool",
                .signature = "pub fn isEnabled() bool",
                .doc = "Returns `true` \xe2\x80\x94 the cache module is always enabled at compile time.",
                .kind = "fn",
                .line = 384,
            },
            .{
                .anchor = "pub-fn-isinitialized-bool",
                .signature = "pub fn isInitialized() bool",
                .doc = "Returns whether the cache has been initialized via `init`.",
                .kind = "fn",
                .line = 389,
            },
            .{
                .anchor = "pub-fn-get-key-const-u8-cacheerror-const-u8",
                .signature = "pub fn get(key: []const u8) CacheError!?[]const u8",
                .doc = "Look up a cached value by key. Returns the value slice (borrowed from\nthe cache) or `null` if the key is absent or expired. Thread-safe.\n\nFor FIFO/Random eviction (no promotion needed), uses a shared read lock\nto allow concurrent readers. For LRU/LFU, uses an exclusive lock since\npromotion mutates the list/frequency.",
                .kind = "fn",
                .line = 399,
            },
            .{
                .anchor = "pub-fn-put-key-const-u8-value-const-u8-cacheerror-void",
                .signature = "pub fn put(key: []const u8, value: []const u8) CacheError!void",
                .doc = "Insert a key-value pair using the default TTL from config.",
                .kind = "fn",
                .line = 452,
            },
            .{
                .anchor = "pub-fn-putwithttl-key-const-u8-value-const-u8-ttl-ms-u64-cacheerror-void",
                .signature = "pub fn putWithTtl(key: []const u8, value: []const u8, ttl_ms: u64) CacheError!void",
                .doc = "Insert a key-value pair with a specific TTL in milliseconds.\nEvicts entries as needed if the cache is at capacity.",
                .kind = "fn",
                .line = 458,
            },
            .{
                .anchor = "pub-fn-delete-key-const-u8-cacheerror-bool",
                .signature = "pub fn delete(key: []const u8) CacheError!bool",
                .doc = "Remove an entry by key. Returns `true` if the key was present.",
                .kind = "fn",
                .line = 536,
            },
            .{
                .anchor = "pub-fn-contains-key-const-u8-bool",
                .signature = "pub fn contains(key: []const u8) bool",
                .doc = "Test whether a key exists and has not expired (read-only, no eviction promotion).",
                .kind = "fn",
                .line = 549,
            },
            .{
                .anchor = "pub-fn-clear-void",
                .signature = "pub fn clear() void",
                .doc = "Remove all entries from the cache.",
                .kind = "fn",
                .line = 558,
            },
            .{
                .anchor = "pub-fn-size-u32",
                .signature = "pub fn size() u32",
                .doc = "Return the current number of live entries.",
                .kind = "fn",
                .line = 576,
            },
            .{
                .anchor = "pub-fn-stats-cachestats",
                .signature = "pub fn stats() CacheStats",
                .doc = "Snapshot hit/miss counters, entry count, memory usage, and eviction stats.",
                .kind = "fn",
                .line = 584,
            },
        },
    },
