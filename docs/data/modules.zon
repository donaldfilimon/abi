            },
        },
    },
    .{
        .name = "storage",
        .path = "src/features/storage/mod.zig",
        .description = "Storage Module\n\nUnified file/object storage with vtable-based backend abstraction.\n\nArchitecture:\n- Backend vtable: put/get/delete/list/exists/deinit function pointers\n- Memory backend: StringHashMap-based in-memory storage\n- Local backend: Planned (requires I/O backend init)\n- S3/GCS: Planned (requires HTTP client)\n\nSecurity: path traversal validation on all keys.",
        .category = "Data & Storage",
        .build_flag = "feat_storage",
        .symbols = .{
