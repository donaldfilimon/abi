    .{
        .name = "auth",
        .path = "src/features/auth/mod.zig",
        .description = "Auth Module\n\nAuthentication and security infrastructure for the ABI framework.\nRe-exports the full security infrastructure from `services/shared/security/`.\n\nWhen the `auth` feature is enabled, all security sub-modules are available:\n- `abi.auth.jwt` \xe2\x80\x94 JSON Web Tokens (HMAC-SHA256/384/512)\n- `abi.auth.api_keys` \xe2\x80\x94 API key management with secure hashing\n- `abi.auth.rbac` \xe2\x80\x94 Role-based access control\n- `abi.auth.session` \xe2\x80\x94 Session management\n- `abi.auth.password` \xe2\x80\x94 Secure password hashing (Argon2id, PBKDF2, scrypt)\n- `abi.auth.cors` \xe2\x80\x94 Cross-Origin Resource Sharing\n- `abi.auth.rate_limit` \xe2\x80\x94 Token bucket, sliding window, leaky bucket\n- `abi.auth.encryption` \xe2\x80\x94 AES-256-GCM, ChaCha20-Poly1305\n- `abi.auth.tls` / `abi.auth.mtls` \xe2\x80\x94 Transport security\n- `abi.auth.certificates` \xe2\x80\x94 X.509 certificate management\n- `abi.auth.secrets` \xe2\x80\x94 Encrypted credential storage\n- `abi.auth.audit` \xe2\x80\x94 Tamper-evident security event logging\n- `abi.auth.validation` \xe2\x80\x94 Input sanitization\n- `abi.auth.ip_filter` \xe2\x80\x94 IP allow/deny lists\n- `abi.auth.headers` \xe2\x80\x94 Security headers middleware",
        .category = "Utilities",
        .build_flag = "feat_auth",
        .symbols = .{
            .{
                .anchor = "pub-fn-init-std-mem-allocator-config-authconfig-autherror-void",
                .signature = "pub fn init(_: std.mem.Allocator, config: AuthConfig) AuthError!void",
                .doc = "Initialise the auth module with a caller-provided config.\nIf `config.jwt_secret` is set, it will be used for all subsequent token\noperations.  Otherwise the default dev secret is used and a warning is\nprinted to stderr.",
                .kind = "fn",
                .line = 103,
            },
            .{
                .anchor = "pub-fn-createtoken-allocator-std-mem-allocator-user-id-const-u8-autherror-token",
                .signature = "pub fn createToken( allocator: std.mem.Allocator, user_id: []const u8, ) AuthError!Token",
                .doc = "Create a signed JWT token for the given user_id.\nDelegates to `jwt.JwtManager.createToken` from `services/shared/security/jwt.zig`.",
                .kind = "fn",
                .line = 134,
            },
            .{
                .anchor = "pub-fn-verifytoken-token-str-const-u8-autherror-token",
                .signature = "pub fn verifyToken(token_str: []const u8) AuthError!Token",
                .doc = "Verify a JWT token string and return parsed token info.\nDelegates to `jwt.JwtManager.verifyToken` from `services/shared/security/jwt.zig`.\nUses the default dev secret; production callers should use `jwt.JwtManager`\ndirectly with their own secret.\n\nNote: The returned Token's `.claims.sub` is heap-allocated via page_allocator\nwhen non-empty and should be freed by the caller if needed. The `.raw` field\npoints to the input `token_str` (caller-owned, not duped).",
                .kind = "fn",
                .line = 163,
            },
            .{
                .anchor = "pub-fn-createsession-allocator-std-mem-allocator-user-id-const-u8-autherror-session",
                .signature = "pub fn createSession( allocator: std.mem.Allocator, user_id: []const u8, ) AuthError!Session",
                .doc = "Create a new session for the given user_id.\nDelegates to `session.SessionManager.create` from\n`services/shared/security/session.zig`.\n\nThe returned `Session.id` and `Session.user_id` are heap-allocated via the\nprovided allocator; callers should free them when done (or use an arena).",
                .kind = "fn",
                .line = 212,
            },
            .{
                .anchor = "pub-fn-checkpermission-user-id-const-u8-permission-permission-autherror-bool",
                .signature = "pub fn checkPermission(user_id: []const u8, permission: Permission) AuthError!bool",
                .doc = "Check if a user has a given permission.\nDelegates to `rbac.RbacManager.hasPermission` from\n`services/shared/security/rbac.zig`.\n\nMaps the auth-level `Permission` enum to the RBAC module's `Permission`.\nCreates an ephemeral RbacManager with default roles. Without explicit\nrole assignment the user will have no permissions, so this returns false\nby default \xe2\x80\x94 callers needing real RBAC should use `rbac.RbacManager`\ndirectly and assign roles.",
                .kind = "fn",
                .line = 267,
            },
        },
    },
