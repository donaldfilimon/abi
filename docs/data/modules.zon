                .doc = "Tear down the messaging subsystem and all topics/subscribers.",
                .kind = "fn",
                .line = 244,
            },
            .{
                .anchor = "pub-fn-publish-allocator-std-mem-allocator-topic-name-const-u8-payload-const-u8-messagingerror-void",
                .signature = "pub fn publish( allocator: std.mem.Allocator, topic_name: []const u8, payload: []const u8, ) MessagingError!void",
                .doc = "Publish a message to a topic. Delivers synchronously to all matching\nsubscribers (exact match and MQTT-style wildcards `*`, `#`).",
                .kind = "fn",
                .line = 261,
            },
            .{
                .anchor = "pub-fn-subscribe-std-mem-allocator-topic-pattern-const-u8-callback-subscribercallback-user-ctx-anyopaque-messagingerror-u64",
