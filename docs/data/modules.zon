    .{
        .name = "search",
        .path = "src/features/search/mod.zig",
        .description = "Search Module\n\nFull-text search with inverted index, BM25 scoring, tokenization,\nand snippet generation.\n\nArchitecture:\n- Named indexes (SwissMap of name \xe2\x86\x92 InvertedIndex)\n- Inverted index: term \xe2\x86\x92 PostingList (doc_id, term_freq, positions)\n- BM25 scoring: IDF \xc3\x97 TF component with configurable k1, b\n- Tokenizer: lowercase, stop word removal\n- Snippet: window with highest match density",
        .category = "Data & Storage",
        .build_flag = "feat_search",
        .symbols = .{
            .{
                .anchor = "pub-fn-init-allocator-std-mem-allocator-config-searchconfig-searcherror-void",
