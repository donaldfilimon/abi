                .signature = "pub fn query( allocator: std.mem.Allocator, index_name: []const u8, query_text: []const u8, ) SearchError![]SearchResult",
                .doc = "Execute a BM25-scored full-text query against a named index.\nResults are sorted by relevance and include context snippets.",
                .kind = "fn",
                .line = 553,
            },
            .{
