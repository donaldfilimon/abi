#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC="$REPO_ROOT/tools/cel/stage0/main.c"
OUT_DIR="$REPO_ROOT/.cel-stage0/bin"
OUT="$OUT_DIR/cel"

needs_rebuild=0
if [[ ! -x "$OUT" ]]; then
    needs_rebuild=1
elif [[ "$SRC" -nt "$OUT" || "$0" -nt "$OUT" ]]; then
    needs_rebuild=1
fi

if [[ "$needs_rebuild" -eq 1 ]]; then
    mkdir -p "$OUT_DIR"
    "${CC:-cc}" \
        -std=c11 \
        -D_POSIX_C_SOURCE=200809L \
        -Wall \
        -Wextra \
        -Werror \
        -pedantic \
        -O2 \
        "$SRC" \
        -o "$OUT"
fi

exec "$OUT" "$@"
