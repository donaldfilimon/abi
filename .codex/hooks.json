{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "npx --package=@stylusnexus/skill-loop skill-loop-claude pre-hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; case \"$f\" in *.zig) zig fmt \"$f\";; esac; } 2>/dev/null || true",
            "statusMessage": "zig fmt"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "npx --package=@stylusnexus/skill-loop skill-loop-claude post-hook"
          }
        ]
      }
    ]
  }
}
