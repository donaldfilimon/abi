--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -915,6 +915,13 @@ set(ZIG_BUILD_ARGS
   -Dno-langref
 )
 
+if(CMAKE_HOST_SYSTEM_NAME STREQUAL "Darwin" AND CMAKE_HOST_SYSTEM_VERSION VERSION_GREATER_EQUAL 26)
+  # The `zig build` runner links before build.zig can request LLVM/LLD. Force
+  # the build command itself onto the LLVM+LLD path so stage3 can link on
+  # macOS 26+ hosts.
+  list(APPEND ZIG_BUILD_ARGS -fllvm -flld)
+endif()
+
 set(ZIG_EXTRA_BUILD_ARGS "" CACHE STRING "Extra zig build args")
 if(ZIG_EXTRA_BUILD_ARGS)
   list(APPEND ZIG_BUILD_ARGS ${ZIG_EXTRA_BUILD_ARGS})
