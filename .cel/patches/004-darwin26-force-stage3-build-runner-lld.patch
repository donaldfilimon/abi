--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -915,6 +915,11 @@ set(ZIG_BUILD_ARGS
   -Dno-langref
 )
 
+# The `zig build` runner links before build.zig can request LLVM/LLD. Force
+# the stage3 build command itself onto the LLVM+LLD path so CEL builds use
+# the same linker path as the final compiler.
+list(APPEND ZIG_BUILD_ARGS -fllvm -flld)
+
 set(ZIG_EXTRA_BUILD_ARGS "" CACHE STRING "Extra zig build args")
 if(ZIG_EXTRA_BUILD_ARGS)
   list(APPEND ZIG_BUILD_ARGS ${ZIG_EXTRA_BUILD_ARGS})
