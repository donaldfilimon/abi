{
  "name": "abi-framework",
  "version": "1.0.0",
  "description": "ABI Framework - Multi-AI orchestration with Zig 0.17",
  "skills": [
    "run-abi",
    "mcp-smoke",
    "agent-plan-train",
    "dashboard-smoke",
    "wdbx-roundtrip",
    "wdbx-api-serve",
    "wdbx-cluster-serve",
    "wdbx-bench",
    "secure-demo",
    "nn-demo",
    "scheduler-status",
    "complete-base",
    "sea-learn-loop",
    "backend-diagnostics",
    "auth-localcheck",
    "connector-localcheck",
    "os-control-dryrun",
    "cross-compile-check",
    "zig-pin",
    "zig-newest-skills",
    "docs-validate",
    "cluster-demo-guide",
    "plugin-runtime-tester",
    "check-work",
    "goals",
    "ai-plan",
    "tui",
    "wdbx",
    "mcp",
    "gpu",
    "sea"
  ],
  "mcp": {
    "servers": {
      "abi-mcp": {
        "command": "zig-out/bin/abi-mcp",
        "args": []
      },
      "skill-loop": {
        "command": "npx",
        "args": ["@modelcontextprotocol/server-skill-loop"]
      }
    }
  },
  "commands": {
    "abi": {
      "description": "Run abi CLI commands",
      "command": "zig-out/bin/abi"
    },
    "abi-check": {
      "description": "Run abi build check",
      "command": "./build.sh check"
    },
    "abi-test": {
      "description": "Run abi tests with filter",
      "command": "zig build test -Dtest-filter"
    },
    "abi-lint": {
      "description": "Run abi lint/format",
      "command": "zig build lint"
    },
    "abi-parity": {
      "description": "Check mod/stub parity",
      "command": "zig build check-parity"
    }
  },
  "slash_commands": {
    "open": {
      "description": "Load file into context",
      "skill": "file-context-loader"
    },
    "diff": {
      "description": "Show git diff",
      "skill": "git-diff-integration"
    },
    "commit": {
      "description": "Create git commit",
      "skill": "git-commit-integration"
    },
    "context": {
      "description": "Show context state",
      "skill": "context-state-reporter"
    },
    "features": {
      "description": "Show build-time feature flags",
      "skill": "feature-flag-display"
    },
    "learn": {
      "description": "Toggle SEA self-learning mode",
      "skill": "sea-learning-controller"
    },
    "save": {
      "description": "Save session",
      "skill": "session-persister"
    },
    "load": {
      "description": "Load session",
      "skill": "session-restorer"
    },
    "status": {
      "description": "Show agent status",
      "skill": "agent-status-reporter"
    },
    "reset": {
      "description": "Reset context/history",
      "skill": "context-resetter"
    }
  },
  "superpowers": {
    "enabled": true,
    "plugins": [
      "abi-superpower-ai",
      "abi-superpower-wdbx",
      "abi-superpower-tui",
      "abi-superpower-mcp",
      "abi-superpower-gpu",
      "abi-superpower-sea"
    ]
  }
}
